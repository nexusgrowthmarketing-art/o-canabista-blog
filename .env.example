# URL pública do site (usada em metadata, sitemap, robots, canonical e Open Graph)
NEXT_PUBLIC_SITE_URL=https://ocanabista.com.br

# Senha de acesso ao painel /admin (protótipo). Troque por uma senha forte.
ADMIN_PASSWORD=canabista

# --- Supabase (banco de dados) ---
# Se estas duas existirem, o app usa o Supabase; se não, usa arquivos locais.
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
# SECRETO — nunca exponha no navegador nem no Git. Só no servidor/Vercel.
SUPABASE_SERVICE_ROLE_KEY=cole-aqui-a-service-role-key
