# Normaliza quebras de linha entre Windows (você) e Mac/Linux (designer).
# Evita "quebra" de arquivos por diferença de CRLF/LF.
* text=auto eol=lf

# Binários não devem ser normalizados.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.mp4 binary
